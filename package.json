{
  "name": "mysql-ddl-archive",
  "version": "1.0.0",
  "description": "Takes a snapshot of a MySQL server's DDL structure, maintaining a history.",
  "type": "module",
  "bin": {
    "mysql-ddl-archive": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-strip-types src/index.ts",
    "dev": "node --experimental-strip-types src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "mysql2": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
